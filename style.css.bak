/* =====================================================
   ELITE PORTFOLIO DESIGN SYSTEM
   Professional • Precise • Production-Ready
   ===================================================== */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

/* =====================================================
   DESIGN TOKENS - Foundation Layer
   ===================================================== */

:root {
    /* Core Colors */
    --primary: #0f172a;
    --primary-accent: #3b82f6;
    --primary-accent-hover: #2563eb;
    --primary-accent-dark: #1d4ed8;
    
    /* Secondary */
    --secondary: #06b6d4;
    --secondary-hover: #0891b2;
    
    /* Neutral Palette */
    --gray-50: #f8fafc;
    --gray-100: #f1f5f9;
    --gray-200: #e2e8f0;
    --gray-300: #cbd5e1;
    --gray-400: #94a3b8;
    --gray-500: #64748b;
    --gray-600: #475569;
    --gray-700: #334155;
    --gray-800: #1e293b;
    --gray-900: #0f172a;
    
    /* Semantic */
    --text-primary: #0f172a;
    --text-secondary: #475569;
    --text-tertiary: #64748b;
    --bg-white: #ffffff;
    --bg-light: #f8fafc;
    --border-color: #e2e8f0;
    
    /* Typography */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    
    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;
    --space-24: 6rem;
    --space-32: 8rem;
    
    /* Border Radius */
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 1.5rem;
    
    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    
    /* Transitions */
    --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============================================
   GLOBAL STYLES
   ============================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-primary);
    background: var(--bg-white);
    overflow-x: hidden;
}

a {
    color: var(--primary-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--primary-accent-hover);
}

button {
    font-family: inherit;
    border: none;
    cursor: pointer;
}

/* ============================================
   NAVIGATION
   ============================================ */

.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-color);
    z-index: 1000;
    box-shadow: var(--shadow-sm);
}

.nav-wrapper {
    width: 100%;
    height: 100%;
    padding: 0 var(--space-4);
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
}

.nav-brand a {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--primary-accent);
    letter-spacing: -0.02em;
    transition: all var(--transition-fast);
}

.nav-brand a:hover {
    transform: translateY(-2px);
}

.nav-toggle {
    display: none;
    flex-direction: column;
    gap: var(--space-2);
    background: transparent;
    padding: var(--space-2);
    z-index: 1001;
}

.toggle-icon {
    width: 24px;
    height: 2px;
    background: var(--primary);
    transition: all var(--transition-fast);
    border-radius: 2px;
}

.nav-toggle.active .toggle-icon:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
}

.nav-toggle.active .toggle-icon:nth-child(2) {
    opacity: 0;
}

.nav-toggle.active .toggle-icon:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
}

.nav-menu {
    display: flex;
    gap: var(--space-8);
    list-style: none;
    align-items: center;
}

.nav-item {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    padding: 0;
    transition: color var(--transition-fast);
}

.nav-item::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-accent);
    transition: width var(--transition-fast);
    border-radius: 2px;
}

.nav-item:hover {
    color: var(--primary-accent);
}

.nav-item:hover::after {
    width: 100%;
}

.nav-item.active {
    color: var(--primary-accent);
}

.nav-item.active::after {
    width: 100%;
}

@media (max-width: 768px) {
    .nav-toggle {
        display: flex;
    }

    .nav-menu {
        position: absolute;
        top: 70px;
        left: 0;
        right: 0;
        flex-direction: column;
        gap: 0;
        background: var(--bg-white);
        border-bottom: 1px solid var(--border-color);
        max-height: 0;
        overflow: hidden;
        transition: max-height var(--transition-base);
    }

    .nav-menu.active {
        max-height: 400px;
    }

    .nav-item {
        width: 100%;
        padding: var(--space-4);
        border-bottom: 1px solid var(--border-color);
    }

    .nav-item::after {
        display: none;
    }
}

/* ============================================
   HERO SECTION
   ============================================ */

.hero {
    padding: 120px var(--space-4) 80px;
    background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}

.hero-container {
    max-width: 800px;
    width: 100%;
}

.hero-label {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-accent);
    background: rgba(59, 130, 246, 0.1);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-6);
    letter-spacing: 0.5px;
}

.hero-title {
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    line-height: 1.2;
    color: var(--primary);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
}

.hero-desc {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-8);
    max-width: 600px;
}

.hero-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
    cursor: pointer;
    white-space: nowrap;
}

.btn-primary {
    background: var(--primary-accent);
    color: white;
    box-shadow: var(--shadow-md);
}

.btn-primary:hover {
    background: var(--primary-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-secondary {
    background: transparent;
    color: var(--primary-accent);
    border: 2px solid var(--primary-accent);
}

.btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--primary-accent-hover);
    color: var(--primary-accent-hover);
}

.hero-meta {
    display: flex;
    gap: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-color);
}

.meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.meta-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.meta-value {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--primary);
}

/* ============================================
   CONTAINER & SECTIONS
   ============================================ */

.container {
    width: 100%;
    max-width: 1200px;
    padding: 0 var(--space-4);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
}

section {
    scroll-margin-top: 70px;
}

.about,
.experience,
.projects,
.contact {
    padding: 80px var(--space-4);
}

@media (max-width: 768px) {
    .about,
    .experience,
    .projects,
    .contact {
        padding: 60px var(--space-4);
    }
}

.section-heading {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 900;
    color: var(--primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-16);
    text-align: center;
}

/* ============================================
   ABOUT SECTION
   ============================================ */

.about {
    background: var(--bg-white);
}

.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
}

.about-text p {
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    line-height: 1.8;
    font-size: 1.0625rem;
}

.about-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
}

.highlight-card {
    padding: var(--space-8);
    background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-color);
    text-align: center;
    transition: all var(--transition-base);
}

.highlight-card:hover {
    border-color: var(--primary-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
}

.highlight-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--primary-accent);
    margin-bottom: var(--space-2);
}

.highlight-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

@media (max-width: 768px) {
    .about-grid {
        grid-template-columns: 1fr;
        gap: var(--space-12);
    }

    .about-highlights {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* ============================================
   EXPERIENCE / SKILLS SECTION
   ============================================ */

.experience {
    background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
}

.skills-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-12);
}

.skill-group {
    background: var(--bg-white);
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-color);
    transition: all var(--transition-base);
}

.skill-group:hover {
    border-color: var(--primary-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.skill-group-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: var(--space-6);
}

.skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
}

.skill-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    background: rgba(59, 130, 246, 0.1);
    color: var(--primary-accent);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid rgba(59, 130, 246, 0.3);
    transition: all var(--transition-fast);
}

.skill-badge:hover {
    background: var(--primary-accent);
    color: white;
    border-color: var(--primary-accent);
}

/* ============================================
   PROJECTS SECTION
   ============================================ */

.projects {
    background: var(--bg-white);
}

.projects-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
}

.project-card {
    padding: var(--space-8);
    background: var(--bg-white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
}

.project-card:hover {
    border-color: var(--primary-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
}

.project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-4);
}

.project-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    margin: 0;
}

.project-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(59, 130, 246, 0.1);
    color: var(--primary-accent);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.project-description {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-6);
}

.project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
}

.tech-tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(59, 130, 246, 0.08);
    color: var(--primary-accent);
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    font-weight: 500;
    border: 1px solid rgba(59, 130, 246, 0.2);
}

.project-footer {
    display: flex;
    gap: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-color);
}

.project-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--primary-accent);
    transition: all var(--transition-fast);
    position: relative;
}

.project-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-accent);
    transition: width var(--transition-fast);
}

.project-link:hover::after {
    width: 100%;
}

/* ============================================
   CONTACT SECTION
   ============================================ */

.contact {
    background: linear-gradient(135deg, #f8fafc 0%, #f0f9ff 100%);
}

.contact-wrapper {
    max-width: 1000px;
}

.contact-header {
    text-align: center;
    margin-bottom: var(--space-16);
}

.contact-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: var(--space-6);
}

.contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
}

.contact-form-container {
    background: var(--bg-white);
    padding: var(--space-10);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-color);
}

.contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
}

.form-group {
    display: flex;
    flex-direction: column;
}

.form-input,
.form-textarea {
    padding: var(--space-3) var(--space-4);
    font-size: 1rem;
    font-family: inherit;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
    background: var(--bg-white);
    color: var(--text-primary);
}

.form-input:focus,
.form-textarea:focus {
    outline: none;
    border-color: var(--primary-accent);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: var(--text-tertiary);
}

.contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
}

.contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-white);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
    color: var(--text-primary);
    font-weight: 500;
}

.contact-link:hover {
    border-color: var(--primary-accent);
    background: rgba(59, 130, 246, 0.05);
    transform: translateX(4px);
}

.link-icon {
    font-size: 1.25rem;
    min-width: 30px;
    color: var(--primary-accent);
    font-weight: 700;
}

@media (max-width: 768px) {
    .contact-content {
        grid-template-columns: 1fr;
        gap: var(--space-8);
    }
}

/* ============================================
   FOOTER
   ============================================ */

.footer {
    background: var(--primary);
    color: var(--gray-300);
    padding: var(--space-12) var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-8);
}

.footer-links {
    display: flex;
    gap: var(--space-8);
}

.footer-links a {
    color: var(--gray-300);
    font-size: 0.875rem;
    transition: color var(--transition-fast);
}

.footer-links a:hover {
    color: var(--primary-accent);
}

.footer-content p {
    font-size: 0.875rem;
    margin: 0;
}

@media (max-width: 768px) {
    .footer-content {
        flex-direction: column;
        text-align: center;
        gap: var(--space-4);
    }

    .footer-links {
        flex-direction: column;
        gap: var(--space-4);
    }
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

/* ============================================
   RESPONSIVE DESIGN
   ============================================ */

@media (max-width: 768px) {
    .hero {
        padding: 100px var(--space-4) 60px;
        min-height: auto;
    }

    .hero-title {
        font-size: 2rem;
    }

    .hero-desc {
        font-size: 1rem;
    }

    .hero-cta {
        flex-direction: column;
    }

    .btn {
        width: 100%;
    }

    .about-text p {
        font-size: 1rem;
    }

    .project-header {
        flex-direction: column;
        gap: var(--space-4);
    }
}

@media (max-width: 480px) {
    .hero-label {
        font-size: 0.75rem;
    }

    .section-heading {
        font-size: 1.75rem;
        margin-bottom: var(--space-12);
    }

    .container {
        padding: 0 var(--space-3);
    }

    .about,
    .experience,
    .projects,
    .contact {
        padding: 40px var(--space-3);
    }
}

/* ============================================
   PRINT STYLES
   ============================================ */

@media print {
    .navbar,
    .footer {
        display: none;
    }

    body {
        background: white;
    }

    section {
        page-break-inside: avoid;
    }
}

/* ============================================
   ROOT DESIGN TOKENS - Professional Palette
   ============================================ */

:root {
    /* Primary Brand Colors - Professional Blue */
    --primary: #0f172a;                      /* Deep navy (authority) */
    --primary-accent: #3b82f6;               /* Pure blue (action) */
    --primary-accent-hover: #2563eb;         /* Darker blue (interaction) */
    --primary-light: #eff6ff;                /* Light blue (background) */
    
    /* Secondary Accent - Cyan for sophistication */
    --secondary: #06b6d4;                    /* Cyan (highlights) */
    --secondary-light: #ecf8fa;              /* Light cyan (background) */
    
    /* Status Colors */
    --success: #10b981;
    --warning: #f59e0b;
    --error: #ef4444;
    --info: #3b82f6;
    
    /* Neutral Grays - Premium grayscale */
    --gray-50: #fafbfc;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #2d3748;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --gray-950: #030712;
    
    /* Semantic Colors */
    --white: #ffffff;
    --black: #000000;
    --text-primary: #0f172a;
    --text-secondary: #64748b;
    --text-tertiary: #94a3b8;
    --border: #e2e8f0;
    --border-light: #f1f5f9;
    --bg-light: #f8fafc;
    --bg-default: #ffffff;
    --bg-dark: #0f172a;
    --glass: rgba(255, 255, 255, 0.85);
    --glass-dark: rgba(15, 23, 42, 0.85);
    
    /* Typography System */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    
    /* Font Sizes - 8px scale (mobile-first) */
    --font-size-xs: 0.75rem;                 /* 12px */
    --font-size-sm: 0.875rem;                /* 14px */
    --font-size-base: 1rem;                  /* 16px */
    --font-size-lg: 1.125rem;                /* 18px */
    --font-size-xl: 1.25rem;                 /* 20px */
    --font-size-2xl: 1.5rem;                 /* 24px */
    --font-size-3xl: 1.875rem;               /* 30px */
    --font-size-4xl: 2.25rem;                /* 36px */
    --font-size-5xl: 3rem;                   /* 48px */
    
    /* Line Heights */
    --lh-tight: 1.25;
    --lh-snug: 1.375;
    --lh-normal: 1.5;
    --lh-relaxed: 1.625;
    --lh-loose: 2;
    
    /* Spacing Scale - 4px base */
    --space-0: 0;
    --space-1: 0.25rem;                      /* 4px */
    --space-2: 0.5rem;                       /* 8px */
    --space-3: 0.75rem;                      /* 12px */
    --space-4: 1rem;                         /* 16px */
    --space-5: 1.25rem;                      /* 20px */
    --space-6: 1.5rem;                       /* 24px */
    --space-8: 2rem;                         /* 32px */
    --space-10: 2.5rem;                      /* 40px */
    --space-12: 3rem;                        /* 48px */
    --space-16: 4rem;                        /* 64px */
    --space-20: 5rem;                        /* 80px */
    --space-24: 6rem;                        /* 96px */
    
    /* Border Radius - Modern & Consistent */
    --radius-sm: 0.375rem;                   /* 6px */
    --radius-md: 0.5rem;                     /* 8px */
    --radius-lg: 0.75rem;                    /* 12px */
    --radius-xl: 1rem;                       /* 16px */
    --radius-2xl: 1.5rem;                    /* 24px */
    --radius-3xl: 2rem;                      /* 32px */
    
    /* Shadows - Elevation System */
    --shadow-none: none;
    --shadow-xs: 0 1px 2px 0 rgba(0, 0, 0, 0.03);
    --shadow-sm: 0 1px 3px 0 rgba(0, 0, 0, 0.08), 0 1px 2px 0 rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    
    /* Transitions - Professional Speed */
    --transition-fast: 120ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 300ms cubic-bezier(0.4, 0, 0.2, 1);
    
    /* Z-index System */
    --z-0: 0;
    --z-10: 10;
    --z-20: 20;
    --z-30: 30;
    --z-40: 40;
    --z-50: 50;
}

/* ============================================
   GLOBAL RESETS & BASE STYLES
   ============================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    -webkit-text-size-adjust: 100%;
    font-feature-settings: "kern" 1;
    font-variant-ligatures: contextual;
}

body {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: var(--lh-normal);
    color: var(--text-primary);
    background-color: var(--bg-default);
    font-weight: 400;
    -webkit-font-feature-settings: "kern" 1;
    -moz-font-feature-settings: "kern" 1;
}

/* Links - Clean & Intentional */
a {
    color: var(--primary-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
}

a:hover {
    color: var(--primary-accent-hover);
}

a:focus-visible {
    outline: 2px solid var(--primary-accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
}

/* Headings - Professional Hierarchy */
h1, h2, h3, h4, h5, h6 {
    font-weight: 700;
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
    color: var(--text-primary);
}

h1 { font-size: var(--font-size-5xl); }
h2 { font-size: var(--font-size-4xl); }
h3 { font-size: var(--font-size-2xl); }
h4 { font-size: var(--font-size-xl); }
h5 { font-size: var(--font-size-lg); }
h6 { font-size: var(--font-size-base); }

/* Paragraphs - Readable Line Length */
p {
    margin-bottom: var(--space-4);
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
}

p:last-child {
    margin-bottom: 0;
}

/* Code - Professional Styling */
code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--bg-light);
    padding: 0.2em 0.5em;
    border-radius: var(--radius-sm);
    color: #d73a49;
    letter-spacing: -0.5px;
}

pre {
    background-color: var(--gray-900);
    color: #f1f5f9;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: var(--lh-relaxed);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

pre code {
    background: none;
    padding: 0;
    color: inherit;
}

/* ============================================
   CONTAINER & LAYOUT SYSTEM
   ============================================ */

.container {
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--space-4);
    display: flex;
    flex-direction: column;
    align-items: center;
}

@media (min-width: 480px) {
    .container {
        padding: 0 var(--space-6);
    }
}

@media (min-width: 768px) {
    .container {
        max-width: 728px;
        padding: 0 var(--space-6);
    }
}

@media (min-width: 1024px) {
    .container {
        max-width: 1016px;
        padding: 0 var(--space-8);
    }
}

@media (min-width: 1280px) {
    .container {
        max-width: 1200px;
    }
}

/* ============================================
   SECTION STYLING & SPACING RHYTHM
   ============================================ */

section {
    scroll-margin-top: 70px;
}

.section-title {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: var(--text-primary);
    text-align: center;
    margin-bottom: var(--space-12);
    position: relative;
    letter-spacing: -0.02em;
}

/* Animated Underline for Titles */
.section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, var(--primary-accent), var(--secondary));
    margin: var(--space-6) auto 0;
    border-radius: 999px;
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.2);
    animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

@media (min-width: 768px) {
    .section-title {
        font-size: var(--font-size-4xl);
        margin-bottom: var(--space-16);
    }

    .section-title::after {
        width: 70px;
        height: 5px;
    }
}

@media (min-width: 1024px) {
    .section-title {
        font-size: var(--font-size-5xl);
    }
}

/* ============================================
   NAVIGATION - Premium Glassmorphism
   ============================================ */

.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.08);
    z-index: var(--z-50);
    display: flex;
    align-items: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    will-change: backdrop-filter, transform;
    -webkit-transform: translate3d(0, 0, 0);
}

.nav-container {
    width: 100%;
    height: 100%;
    padding: 0 var(--space-4);
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
}

/* Logo - Confident & Minimal */
.nav-logo a {
    font-size: var(--font-size-xl);
    font-weight: 900;
    color: var(--primary-accent);
    text-decoration: none;
    letter-spacing: -0.03em;
    transition: all var(--transition-fast);
    position: relative;
    display: flex;
    align-items: center;
}

.nav-logo a:hover {
    color: var(--primary-accent-hover);
    transform: translateY(-2px);
}

/* Desktop Navigation Menu */
.nav-menu {
    display: none;
    align-items: center;
    list-style: none;
    gap: var(--space-8);
    margin: 0;
}

.nav-item {
    padding: 0;
    border: 0;
}

.nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: var(--font-size-sm);
    padding: var(--space-2) var(--space-3);
    border-bottom: 2px solid transparent;
    transition: all var(--transition-fast);
    position: relative;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 700;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--primary-accent), var(--secondary));
    transition: width var(--transition-base);
}

.nav-link:hover,
.nav-link.active {
    color: var(--primary-accent);
}

.nav-link:hover::after,
.nav-link.active::after {
    width: 100%;
}

/* Mobile Hamburger */
.hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    width: 24px;
    height: 24px;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
}

.hamburger span {
    width: 24px;
    height: 2.5px;
    background-color: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-fast);
}

.hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translateY(10px);
}

.hamburger.active span:nth-child(2) {
    opacity: 0;
}

.hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translateY(-8px);
}

/* Mobile Menu */
.nav-menu {
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    flex-direction: column;
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    padding: var(--space-4) 0;
    gap: 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

.nav-menu.active {
    display: flex;
}

.nav-menu.active .nav-item {
    width: 100%;
    border-bottom: 1px solid rgba(148, 163, 184, 0.05);
    padding: 0;
}

.nav-menu.active .nav-link {
    display: block;
    padding: var(--space-3) var(--space-6);
    border: none;
    color: var(--text-primary);
}

.nav-menu.active .nav-link::after {
    display: none;
}

.nav-menu.active .nav-link:hover,
.nav-menu.active .nav-link.active {
    background: linear-gradient(90deg, var(--primary-light), var(--secondary-light));
    color: var(--primary-accent);
}

@media (min-width: 768px) {
    .hamburger {
        display: none;
    }

    .nav-menu {
        display: flex;
        position: static;
        width: auto;
        background: none;
        border: none;
        box-shadow: none;
        flex-direction: row;
        padding: 0;
        gap: var(--space-8);
        backdrop-filter: none;
    }

    .nav-item {
        padding: 0;
        border: none;
    }

    .nav-link {
        padding: 0;
        border-bottom: none;
    }

    .nav-container {
        padding: 0 var(--space-6);
    }
}

/* ============================================
   HERO SECTION - Premium & Impactful
   ============================================ */

.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px var(--space-4) var(--space-20) var(--space-4);
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 25%, #334155 50%, #06b6d4 100%);
    background-size: 400% 400%;
    background-attachment: fixed;
    color: var(--white);
    text-align: center;
    position: relative;
    overflow: hidden;
    animation: gradientFlow 15s ease infinite;
    -webkit-font-smoothing: subpixel-antialiased;
    transform: translateZ(0);
}

@keyframes gradientFlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

/* Background Ambience */
.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
        radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(6, 182, 212, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.05) 0%, transparent 60%);
    z-index: 1;
}

.hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    z-index: 1;
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 750px;
    margin: 0 auto;
}

.hero-title {
    font-size: var(--font-size-4xl);
    font-weight: 900;
    margin-bottom: var(--space-4);
    line-height: var(--lh-tight);
    letter-spacing: -0.03em;
    animation: fadeInDown 0.8s ease-out;
    background: linear-gradient(135deg, #ffffff 0%, #e0f2fe 50%, #f0f9ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

.hero-subtitle {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-6);
    opacity: 0.95;
    font-weight: 700;
    letter-spacing: -0.01em;
    animation: fadeInUp 0.8s ease-out 0.1s both;
    color: #bfdbfe;
}

.hero-description {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-10);
    opacity: 0.9;
    line-height: var(--lh-relaxed);
    animation: fadeInUp 0.8s ease-out 0.2s both;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.hero-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    animation: fadeInUp 0.8s ease-out 0.3s both;
    justify-content: center;
}

@media (min-width: 480px) {
    .hero-title {
        font-size: var(--font-size-5xl);
    }

    .hero-buttons {
        flex-direction: row;
        justify-content: center;
        gap: var(--space-6);
    }
}

@media (min-width: 768px) {
    .hero {
        padding: 120px var(--space-6) var(--space-24) var(--space-6);
    }

    .hero-title {
        font-size: 3.5rem;
        margin-bottom: var(--space-6);
    }

    .hero-subtitle {
        font-size: var(--font-size-2xl);
    }

    .hero-description {
        font-size: var(--font-size-lg);
        margin-bottom: var(--space-12);
    }
}

/* ============================================
   BUTTONS - Premium & Interactive
   ============================================ */

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    font-size: var(--font-size-base);
    font-weight: 700;
    font-family: var(--font-sans);
    border: 2px solid transparent;
    border-radius: var(--radius-xl);
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
    line-height: var(--lh-tight);
    gap: var(--space-2);
    letter-spacing: 0.3px;
    box-shadow: var(--shadow-md);
    -webkit-user-select: none;
    user-select: none;
}

.btn:focus-visible {
    outline: 2px solid var(--primary-accent);
    outline-offset: 2px;
}

/* Primary Button - Main CTA */
.btn-primary {
    background: linear-gradient(135deg, var(--primary-accent), var(--secondary));
    color: var(--white);
    border-color: transparent;
    font-weight: 700;
    position: relative;
}

.btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--secondary), var(--primary-accent));
    border-radius: var(--radius-xl);
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: -1;
}

.btn-primary:hover {
    transform: translateY(-3px) translateZ(0);
    box-shadow: 0 15px 40px rgba(59, 130, 246, 0.3);
    letter-spacing: 0.5px;
    -webkit-transform: translateY(-3px) translateZ(0);
}

.btn-primary:active {
    transform: translateY(-1px) translateZ(0);
    box-shadow: 0 5px 15px rgba(59, 130, 246, 0.2);
    -webkit-transform: translateY(-1px) translateZ(0);
}

/* Secondary Button */
.btn-secondary {
    background-color: rgba(255, 255, 255, 0.2);
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.5);
    border-width: 2px;
    font-weight: 700;
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    will-change: backdrop-filter;
}

.btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.3);
    border-color: var(--white);
    transform: translateY(-3px) translateZ(0);
    box-shadow: 0 15px 40px rgba(255, 255, 255, 0.2);
    -webkit-transform: translateY(-3px) translateZ(0);
}

.btn-secondary:active {
    transform: translateY(-1px) translateZ(0);
    -webkit-transform: translateY(-1px) translateZ(0);
}

/* Outline Button */
.btn-outline {
    background-color: transparent;
    color: var(--text-primary);
    border-color: var(--border);
    border-width: 2px;
}

.btn-outline:hover {
    background-color: var(--primary-light);
    border-color: var(--primary-accent);
    color: var(--primary-accent);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
}

/* Size Variations */
.btn-sm {
    padding: 10px 20px;
    font-size: var(--font-size-sm);
}

.btn-lg {
    padding: 16px 40px;
    font-size: var(--font-size-lg);
}

.btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
}

/* ============================================
   ABOUT SECTION
   ============================================ */

.about {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(180deg, var(--bg-default) 0%, var(--bg-light) 100%);
    position: relative;
}

.about::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.15), transparent);
}

.about-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
}

.about-text {
    animation: fadeInUp 0.6s ease-out;
}

.about-text p {
    font-size: var(--font-size-base);
    line-height: var(--lh-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    letter-spacing: 0.2px;
}

.about-text p:last-child {
    margin-bottom: 0;
}

@media (min-width: 768px) {
    .about {
        padding: var(--space-24) var(--space-6);
    }
}

/* ============================================
   SKILLS SECTION - Structured & Scannable
   ============================================ */

.skills {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(180deg, var(--bg-light) 0%, var(--bg-default) 100%);
}

.skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    max-width: 1200px;
    margin: 0 auto;
}

.skill-category {
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    padding: var(--space-8);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(226, 232, 240, 0.5);
    animation: fadeInUp 0.6s ease-out;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    transition: all var(--transition-base);
    will-change: transform, box-shadow;
}

.skill-category:hover {
    transform: translateY(-4px) translateZ(0);
    box-shadow: 0 12px 40px rgba(59, 130, 246, 0.12);
    border-color: rgba(59, 130, 246, 0.2);
    -webkit-transform: translateY(-4px) translateZ(0);
}

.skill-category-title {
    font-size: var(--font-size-lg);
    font-weight: 800;
    color: var(--primary-accent);
    margin-bottom: var(--space-6);
    text-align: left;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-size: 0.85rem;
}

.skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: flex-start;
}

.skill-tag {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.9), rgba(6, 182, 212, 0.7));
    color: var(--white);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-2xl);
    font-size: var(--font-size-sm);
    font-weight: 700;
    transition: all var(--transition-base);
    border: 1px solid rgba(255, 255, 255, 0.2);
    cursor: default;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.15);
    letter-spacing: 0.3px;
    position: relative;
    overflow: hidden;
}

.skill-tag::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent);
    opacity: 0;
    transition: opacity var(--transition-fast);
}

.skill-tag:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.25);
    border-color: rgba(255, 255, 255, 0.4);
}

@media (min-width: 768px) {
    .skills {
        padding: var(--space-24) var(--space-6);
    }

    .skills-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-16);
    }
}

@media (min-width: 1024px) {
    .skills-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-16);
    }
}

/* ============================================
   PROJECTS SECTION - Product-Style Cards
   ============================================ */

.projects {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(180deg, var(--bg-default) 0%, var(--bg-light) 100%);
}

.projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    max-width: 1200px;
    margin: 0 auto;
}

.project-card {
    background: var(--white);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all var(--transition-base);
    animation: fadeInUp 0.6s ease-out;
    border: 1px solid rgba(226, 232, 240, 0.6);
    display: flex;
    flex-direction: column;
    position: relative;
    will-change: transform, box-shadow;
}

.project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--primary-accent), var(--secondary));
    z-index: 1;
}

.project-card:hover {
    transform: translateY(-12px) translateZ(0);
    box-shadow: 0 20px 60px rgba(59, 130, 246, 0.15);
    border-color: rgba(59, 130, 246, 0.3);
    -webkit-transform: translateY(-12px) translateZ(0);
}

.project-image {
    width: 100%;
    height: 240px;
    background: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-weight: 700;
    font-size: var(--font-size-lg);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
}

.project-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
        radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
        radial-gradient(circle at 70% 70%, rgba(0, 0, 0, 0.1) 0%, transparent 50%);
    z-index: 0;
}

.project-card:hover .project-image {
    background: linear-gradient(135deg, var(--secondary) 0%, var(--primary-accent) 100%);
    transform: scale(1.05) translateZ(0);
    -webkit-transform: scale(1.05) translateZ(0);
}

.placeholder-image {
    text-align: center;
    letter-spacing: 0.5px;
    position: relative;
    z-index: 1;
    font-size: 1.1rem;
}

.project-info {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    flex: 1;
}

.project-title {
    font-size: var(--font-size-xl);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: var(--lh-snug);
    letter-spacing: -0.01em;
}

.project-description {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    line-height: var(--lh-relaxed);
    flex-grow: 1;
}

.project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
}

.project-tag {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(6, 182, 212, 0.08));
    color: var(--primary-accent);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-2xl);
    font-size: var(--font-size-xs);
    font-weight: 800;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border: 1px solid rgba(59, 130, 246, 0.2);
    transition: all var(--transition-fast);
}

.project-tag:hover {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(6, 182, 212, 0.12));
    border-color: rgba(59, 130, 246, 0.4);
}

.project-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
}

.project-link {
    color: var(--primary-accent);
    text-decoration: none;
    font-weight: 800;
    font-size: var(--font-size-sm);
    padding: var(--space-2) var(--space-3);
    border-bottom: 2px solid transparent;
    transition: all var(--transition-fast);
    position: relative;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
}

.project-link::after {
    content: '→';
    position: absolute;
    right: -8px;
    opacity: 0;
    transition: all var(--transition-fast);
}

.project-link:hover {
    color: var(--secondary);
    border-bottom-color: var(--secondary);
    padding-right: var(--space-4);
}

.project-link:hover::after {
    opacity: 1;
    right: -12px;
}

@media (min-width: 768px) {
    .projects {
        padding: var(--space-24) var(--space-6);
    }

    .projects-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .project-image {
        height: 200px;
    }
}

@media (min-width: 1024px) {
    .project-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
    }

    .project-image {
        height: 100%;
        min-height: 300px;
    }

    .project-info {
        padding: var(--space-10);
    }
}

/* ============================================
   EDUCATION SECTION - Timeline
   ============================================ */

.education {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(180deg, var(--bg-light) 0%, var(--bg-default) 100%);
}

.education-content {
    max-width: 900px;
    margin: 0 auto;
}

.education-item {
    padding-bottom: var(--space-10);
    padding-left: var(--space-8);
    border-left: 2px solid rgba(59, 130, 246, 0.3);
    animation: fadeInUp 0.6s ease-out;
    position: relative;
    transition: all var(--transition-base);
}

.education-item:hover {
    border-left-color: var(--primary-accent);
    padding-left: calc(var(--space-8) + 4px);
}

.education-item::before {
    content: '';
    position: absolute;
    left: -15px;
    top: 0;
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--primary-accent), var(--secondary));
    border-radius: 50%;
    border: 4px solid var(--white);
    box-shadow: 0 0 0 2px var(--border);
    transition: all var(--transition-base);
}

.education-item:hover::before {
    transform: scale(1.2) translateZ(0);
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.4), 0 0 0 4px rgba(59, 130, 246, 0.1);
    -webkit-transform: scale(1.2) translateZ(0);
}

.education-item:last-child {
    border-left-color: transparent;
    padding-bottom: 0;
}

.education-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
}

.education-degree {
    font-size: var(--font-size-lg);
    font-weight: 800;
    color: var(--text-primary);
    flex: 1;
    min-width: 200px;
    line-height: var(--lh-snug);
    letter-spacing: -0.01em;
}

.education-year {
    background: linear-gradient(135deg, var(--primary-light), var(--secondary-light));
    color: var(--primary-accent);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-2xl);
    font-size: var(--font-size-xs);
    font-weight: 800;
    white-space: nowrap;
    border: 1px solid rgba(59, 130, 246, 0.2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.education-school {
    font-size: var(--font-size-base);
    color: var(--primary-accent);
    font-weight: 800;
    margin-bottom: var(--space-2);
    letter-spacing: 0.3px;
}

.education-description {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
}

@media (min-width: 768px) {
    .education {
        padding: var(--space-24) var(--space-6);
    }

    .education-content {
        max-width: 800px;
    }
}

/* ============================================
   CONTACT SECTION - Conversion Focused
   ============================================ */

.contact {
    padding: var(--space-20) var(--space-4);
    background: linear-gradient(180deg, var(--bg-default) 0%, var(--bg-light) 100%);
}

.contact-subtitle {
    text-align: center;
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-12);
    animation: fadeInUp 0.6s ease-out;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0.2px;
}

.contact-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    max-width: 1100px;
    margin: 0 auto;
}

.contact-form {
    display: grid;
    gap: var(--space-6);
    animation: fadeInUp 0.6s ease-out 0.1s both;
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    padding: var(--space-8);
    border-radius: var(--radius-2xl);
    border: 1px solid rgba(226, 232, 240, 0.5);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    will-change: backdrop-filter;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.form-group label {
    font-weight: 800;
    color: var(--text-primary);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-input,
.form-textarea {
    padding: var(--space-4) var(--space-4);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    color: var(--text-primary);
    transition: all var(--transition-base);
    background-color: rgba(255, 255, 255, 0.8);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    -webkit-font-smoothing: subpixel-antialiased;
}

.form-input::placeholder,
.form-textarea::placeholder {
    color: var(--text-tertiary);
}

.form-input:focus,
.form-textarea:focus {
    outline: none;
    border-color: var(--primary-accent);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1), inset 0 0 0 1px rgba(59, 130, 246, 0.1);
    background-color: var(--white);
}

.form-textarea {
    resize: vertical;
    min-height: 140px;
    font-family: var(--font-sans);
}

.contact-info {
    display: grid;
    gap: var(--space-6);
    animation: fadeInUp 0.6s ease-out 0.2s both;
}

.contact-item {
    padding: var(--space-6);
    background: var(--glass);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--primary-accent);
    border: 1px solid rgba(226, 232, 240, 0.5);
    border-left: 4px solid var(--primary-accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    transition: all var(--transition-base);
    will-change: transform, box-shadow;
}

.contact-item:hover {
    box-shadow: 0 12px 40px rgba(59, 130, 246, 0.12);
    transform: translateY(-4px) translateZ(0);
    border-color: rgba(59, 130, 246, 0.2);
    -webkit-transform: translateY(-4px) translateZ(0);
}

.contact-item h3 {
    font-size: var(--font-size-sm);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 800;
}

.contact-item a {
    color: var(--primary-accent);
    text-decoration: none;
    font-weight: 800;
    transition: all var(--transition-fast);
}

.contact-item a:hover {
    color: var(--secondary);
}

.contact-item p {
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
}

.social-links {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
    flex-wrap: wrap;
}

.social-link {
    color: var(--primary-accent);
    text-decoration: none;
    font-weight: 800;
    font-size: var(--font-size-sm);
    padding: var(--space-3) var(--space-5);
    border: 2px solid var(--primary-accent);
    border-radius: var(--radius-2xl);
    transition: all var(--transition-base);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    letter-spacing: 0.3px;
    position: relative;
    overflow: hidden;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 1px;
}

.social-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--primary-accent), var(--secondary));
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: -1;
}

.social-link:hover {
    border-color: var(--primary-accent);
    color: var(--white);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
}

.social-link:hover::before {
    opacity: 1;
}

@media (min-width: 768px) {
    .contact {
        padding: var(--space-24) var(--space-6);
    }

    .contact-content {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-16);
    }
}

/* ============================================
   FOOTER - Minimal & Professional
   ============================================ */

.footer {
    background: linear-gradient(180deg, var(--bg-dark) 0%, var(--gray-950) 100%);
    color: var(--white);
    padding: var(--space-12) var(--space-4);
    text-align: center;
    border-top: 1px solid rgba(226, 232, 240, 0.1);
    position: relative;
    overflow: hidden;
}

.footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.2), transparent);
}

.footer-content {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.footer-content p {
    margin: var(--space-2) 0;
    font-size: var(--font-size-sm);
    opacity: 0.85;
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.2px;
}

.heart {
    color: #ef4444;
    animation: heartbeat 1.5s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
    display: inline-block;
}

@keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.3); }
    50% { transform: scale(1.1); }
}

@media (min-width: 768px) {
    .footer {
        padding: var(--space-12) var(--space-6);
    }

    .footer-content p {
        font-size: var(--font-size-base);
    }
}

/* ============================================
   ANIMATIONS - Smooth & Professional
   ============================================ */

@keyframes fadeInDown {
    from {
        opacity: 0;
        transform: translateY(-30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

@keyframes scaleIn {
    from {
        opacity: 0;
        transform: scale(0.95);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

/* ============================================
   RESPONSIVE DESIGN - Mobile First
   ============================================ */

@media (max-width: 479px) {
    :root {
        --font-size-5xl: 2rem;
        --font-size-4xl: 1.75rem;
        --font-size-3xl: 1.5rem;
    }

    .hero {
        padding: 70px var(--space-4) var(--space-10) var(--space-4);
    }

    .section-title {
        font-size: var(--font-size-2xl);
        margin-bottom: var(--space-10);
    }

    .about, .skills, .projects, .education, .contact {
        padding: var(--space-12) var(--space-4);
    }
}

/* ============================================
   ACCESSIBILITY & PREFERENCES
   ============================================ */

@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }

    html {
        scroll-behavior: auto;
    }
}

@media print {
    .navbar, .hero-buttons, .project-links, .contact-form, .social-links, .footer {
        display: none !important;
    }

    * {
        box-shadow: none !important;
    }
}
